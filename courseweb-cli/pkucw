#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if command -v pkucw >/dev/null 2>&1; then
  exec "$(command -v pkucw)" "$@"
fi

if [[ -x "${SCRIPT_DIR}/.venv/bin/pkucw" ]]; then
  exec "${SCRIPT_DIR}/.venv/bin/pkucw" "$@"
fi

if [[ -x "${HOME}/.local/bin/pkucw" ]]; then
  exec "${HOME}/.local/bin/pkucw" "$@"
fi

PYTHONPATH="${SCRIPT_DIR}/src${PYTHONPATH:+:${PYTHONPATH}}" exec python3 -m courseweb "$@"
